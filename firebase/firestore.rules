rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth.uid == document;
      allow delete: if request.auth.uid == document;
    }

    match /groups/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if /databases/$(database)/documents/users/$(request.auth.uid) in resource.data.memberUserIds;
      allow delete: if resource.data.groupOwner == /databases/$(database)/documents/users/$(request.auth.uid);
    }

    match /venues/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /matches/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /messages/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /events/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /promotions/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /analytics/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /venues/{parent}/interestedDaily/{document} {
      allow create: if false;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /{path=**}/interestedDaily/{document} {
      allow read: if request.auth != null;
    }


    match /venues/{parent}/interestWeekly/{document} {
      allow create: if false;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /{path=**}/interestWeekly/{document} {
      allow read: if request.auth != null;
    }


    match /venues/{parent}/interestMonthly/{document} {
      allow create: if false;
      allow read: if request.auth != null;
      allow write: if false;
      allow delete: if false;
    }

    match /{path=**}/interestMonthly/{document} {
      allow read: if request.auth != null;
    }


    match /groupInvites/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /venues/{parent}/specials/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /{path=**}/specials/{document} {
      allow read: if request.auth != null;
    }

  }
}
